@{
    ViewData["Title"] = "Accessories";
}

<h1>@ViewData["Title"]</h1>

<p>
    Add style to your suit with our curated collection of accessories.
</p>

<div class="row">
    <div class="col-md-4 mb-4">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Ties</h5>
                <p class="card-text">
                    Classic and modern designs in a variety of colors and patterns,
                    suitable for formal and business occasions.
                </p>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-4">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Bow ties</h5>
                <p class="card-text">
                    Elegant bow ties for special events - weddings, proms,
                    and formal dinners.
                </p>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-4">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Belts</h5>
                <p class="card-text">
                    High-quality leather belts that complete any suit look.
                </p>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-4 mb-4">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Pocket squares</h5>
                <p class="card-text">
                    Fine details that give your suit a finished and stylish look.
                </p>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-4">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Cufflinks & buttons</h5>
                <p class="card-text">
                    Elegant cufflinks and buttons, suitable for formal shirts and suits.
                </p>
            </div>
        </div>
    </div>
    <div class="col-md-4 mb-4">
        <div class="card h-100">
            <div class="card-body">
                <h5 class="card-title">Other accessories</h5>
                <p class="card-text">
                    Scarves, suspenders, and other additions that make your look unique.
                </p>
            </div>
        </div>
    </div>
</div>

